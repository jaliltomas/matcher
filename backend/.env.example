APP_NAME=TurboMatcher API
API_PREFIX=
DATA_DIR=./data

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_PREFIX=turbomatcher

# Modelos (se pueden cambiar por rutas locales o IDs de Hugging Face)
BLIP2_MODEL_ID=Salesforce/blip2-opt-2.7b
QWEN_NER_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
QWEN_VALIDATOR_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
RERANKER_MODEL_ID=joeddav/xlm-roberta-large-xnli

# GPU / performance
DEVICE=cuda
DTYPE=float16
BATCH_SIZE=8
IMAGE_DOWNLOAD_WORKERS=24
IMAGE_TIMEOUT_SECONDS=4
MAX_NEW_TOKENS=128
OFFLOAD_BETWEEN_STAGES=true

# Matching defaults
TOP_N_DEFAULT=30
TOP_K_DEFAULT=5
