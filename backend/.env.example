APP_NAME=TurboMatcher API
API_PREFIX=
DATA_DIR=./data

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_PREFIX=turbomatcher

# Modelos (se pueden cambiar por rutas locales o IDs de Hugging Face)
BLIP2_MODEL_ID=Salesforce/blip2-opt-2.7b
QWEN_NER_MODEL_ID=qwen/qwen3.5-9b
QWEN_VALIDATOR_MODEL_ID=qwen/qwen3.5-9b
USE_VLLM=true
VLLM_BASE_URL=http://127.0.0.1:8008/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL_ID=
VLLM_NER_MODEL_ID=
VLLM_VALIDATOR_MODEL_ID=
VLLM_TIMEOUT_SECONDS=120
VLLM_MAX_RETRIES=2
VLLM_DISABLE_THINKING=true
VLLM_MAX_PARALLEL=8
VLLM_CONTEXT_WINDOW=4096
VLLM_CONTEXT_RESERVE=128
RERANKER_MODEL_ID=joeddav/xlm-roberta-large-xnli

# GPU / performance
DEVICE=cuda
DTYPE=float16
BATCH_SIZE=8
IMAGE_DOWNLOAD_WORKERS=24
IMAGE_TIMEOUT_SECONDS=4
MAX_NEW_TOKENS=128
NER_MAX_NEW_TOKENS=256
VALIDATOR_MAX_NEW_TOKENS=256
OFFLOAD_BETWEEN_STAGES=true

# Matching defaults
TOP_N_DEFAULT=30
TOP_K_DEFAULT=5
TH_ACCEPT=0.80
TH_REJECT=0.35
